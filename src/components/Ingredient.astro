---
interface Props {
  ingredient: string;
  description: string;
  quantity: string;
}

const props = Astro.props as Props;
---

<li>
  <div class="items-top flex justify-between">
    <h3 class="text-xl font-bold">
      {props.ingredient}
      <br /><span class="text-muted text-base font-normal italic">{props.description}</span>
    </h3>
    <p class="text-accent text-lg font-bold">{props.quantity}</p>
  </div>
</li>
