---
import type { Ingredient } from "../data/recipe.ts";

type Props = Ingredient;

const { ingredient, description, quantity } = Astro.props;
---

<li class="flex justify-between">
  <h3 class="text-xl font-bold">
    {ingredient}
    <br /><span class="text-muted text-base font-normal italic">{description}</span>
  </h3>
  <p class="text-accent text-lg font-bold">{quantity}</p>
</li>
