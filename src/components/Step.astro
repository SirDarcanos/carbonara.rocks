---
import type { Step } from "../data/recipe.ts";

type Props = Step;

const { step, title, description } = Astro.props;
---

<div class="border-line bg-surface mb-3 flex justify-between gap-4 border border-l-4 p-6 last:mb-0">
  <p class="text-accent font-display text-3xl font-bold">{step}</p>
  <div>
    <h4 class="text-2xl font-bold">{title}</h4>
    <p>{description}</p>
  </div>
</div>
