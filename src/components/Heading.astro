---
import Label from "../components/Label.astro";

interface Props {
  title: string;
  label?: string;
  subtitle?: string;
  color?: string;
}

const { title, label, subtitle, color } = Astro.props;
---

{label && <Label label={label} color={color} />}
<h2 class="font-display mt-3 text-5xl font-bold">{title}</h2>
{subtitle && <p class="font-display text-ink/70 mt-3 text-xl font-semibold italic">{subtitle}</p>}
