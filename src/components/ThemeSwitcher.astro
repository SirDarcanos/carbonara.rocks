<script>
  function setTheme(pref: "light" | "dark" | "system") {
    // pref = "light" | "dark" | "system"
    localStorage.setItem("theme", pref);
    apply();
  }

  function apply() {
    const pref = localStorage.getItem("theme") ?? "system";
    const systemDark = matchMedia("(prefers-color-scheme: dark)").matches;
    const isDark = pref === "dark" || (pref === "system" && systemDark);
    document.documentElement.classList.toggle("dark", isDark);
  }

  matchMedia("(prefers-color-scheme: dark)").addEventListener("change", apply); // react to OS change, only matters in "system"

  document
    .querySelectorAll("[data-theme]")
    .forEach((btn) => btn.addEventListener("click", () => setTheme(btn.dataset.theme)));
</script>
