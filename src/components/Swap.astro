---
interface Props {
  from: string;
  to: string;
  description: string;
}

const { from, to, description } = Astro.props;
---

<div class="bg-surface border-line justify-baseline space-y-4 border p-6">
  <h3 class="font-display text-3xl font-bold">
    {from}
    <span class="text-accent text-lg"> → </span>
    <span class="text-accent text-2xl font-semibold italic">{to}</span>
  </h3>
  <hr class="border-line w-10 border-[0.5px]" />
  <p>{description}</p>
</div>
