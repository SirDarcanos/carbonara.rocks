---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  copy?: string;
  classes?: string;
  widths?: number[];
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  src,
  alt,
  copy,
  classes,
  widths = [480, 768, 1024],
  loading = "lazy",
  fetchpriority = "auto",
} = Astro.props;
---

<figure class="border-line relative w-full border p-1">
  <Picture
    src={src}
    formats={["avif", "webp", "jpeg"]}
    alt={alt}
    class={classes}
    widths={widths}
    sizes="100vw"
    loading={loading}
    fetchpriority={fetchpriority}
  />
  {
    copy && (
      <figcaption class="text-muted bg-surface/85 absolute right-3 bottom-3 px-3 py-1 text-sm backdrop-blur">
        {copy}
      </figcaption>
    )
  }
</figure>
