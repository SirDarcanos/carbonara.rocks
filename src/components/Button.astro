---
interface Props {
  href: string;
  variant?: "solid" | "outline";
}
const { href, variant = "solid" } = Astro.props;
const base = "inline-block px-5 py-3 uppercase tracking-[0.12em] text-sm";
const styles = {
  solid: "bg-accent text-white",
  outline: "border border-accent text-accent",
};
---

<a href={href} class={`${base} ${styles[variant]}`}><slot /></a>
