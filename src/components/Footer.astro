---
import Wordmark from "./Wordmark.astro";
import Container from "./Container.astro";
import Privacy from "./Privacy.astro";
---

<footer class="bg-ink">
  <Container class="flex flex-col items-center justify-between gap-4 py-10 md:flex-row">
    <p class="text-surface text-3xl leading-[0.92] tracking-tight">
      <Wordmark />
    </p>
    <div class="flex flex-col items-center gap-2 md:items-end">
      <p class="text-surface">
        Designed in Italy, without cream &middot; <a
          data-privacy-open
          class="text-surface cursor-pointer hover:underline hover:underline-offset-4">Privacy</a
        >
      </p>
    </div>
  </Container>
</footer>
<Privacy />
